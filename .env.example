APP_VERSION=0.6.0

OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_CHAT_MODEL=auto

WHISPER_MODEL=base
STT_LANGUAGE=ru

RECORD_SECONDS=5
HOTKEY_COMBINATION=<cmd>+<option>+<space>
HOTKEY_TEXT_COMBINATION=<cmd>+<option>+k
HOTKEY_EXIT_COMBINATION=<cmd>+<option>+q
COSYVOICE_REPO_DIR=
COSYVOICE_MODEL_DIR=
COSYVOICE_SPEAKER=

STORAGE_DB_FILE=storage/vasya.db
MEMORY_WIKI_DIR=storage/memory_wiki
MEMORY_BACKGROUND_SYNC_ENABLED=true
MEMORY_BACKGROUND_SYNC_TICK_SECONDS=1200
MEMORY_SYNC_INTERVAL_SECONDS=1200

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=storage/google_token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Europe/Moscow

NOTION_API_TOKEN=
NOTION_UPDATES_PAGE_ID=

GITHUB_API_TOKEN=
GITHUB_DEFAULT_REPO=

VASYA_API_AUTH_TOKEN=
VASYA_API_REQUIRE_AUTH=true
VASYA_API_ALLOW_QUERY_TOKEN=false
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_CHAT_MAX=30
API_RATE_LIMIT_PIPELINE_MAX=20
API_RATE_LIMIT_WS_MESSAGES_MAX=40
API_RATE_LIMIT_WS_CONNECTIONS_MAX=3

LOG_REDACT_SENSITIVE=true
LOG_INCLUDE_TEXT_CONTENT=false
LOG_MAX_FIELD_LENGTH=240

DICTATION_API_ALLOWED_HOSTS=127.0.0.1,localhost
OBSIDIAN_PROJECTS_DIR=01_Projects
OBSIDIAN_DAILY_NOTES_DIR=04_Tasks/Ежедневные
OBSIDIAN_DAILY_NOTES_DIRS=04_Tasks/Ежедневные,04_Tasks/Еженедельные,Daily,Ежедневные,Еженедельные
TASKS_BACKEND=obsidian_daily
